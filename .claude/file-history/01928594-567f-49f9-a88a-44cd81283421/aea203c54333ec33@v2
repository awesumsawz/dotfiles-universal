			display: flex;
			flex-direction: column;
			align-items: center;
			gap: fonts.rem(24px);

			.image-wrapper {
				width: 360px;
				height: 360px;
				border-radius: 21px;
				overflow: hidden;
				background-color: colors.$color-gray-light;

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
