/**
 * Mens OPT Forbes Testosterone
 * Page-specific styles for page-mens-opt-forbes-testosterone.php
 *
 * Desktop-first: base styles target desktop (1440px).
 * Tablet/mobile overrides via $medium-screen-and-smaller (max-width: 1024px).
 * Mobile-only refinements via $small-screen-only (max-width: 600px).
 */
@use '../variables/colors' as colors;
@use '../variables/fonts' as fonts;
@use '../variables/layout' as layout;

.mens-opt-forbes-testosterone {

	> *:not(.linkbar, .navbar, .site-footer) > .container {
		max-width: 1440px;
		margin: 0 auto;
	}
	.extended-center-border-above,
	.extended-center-border-below {
		@media #{layout.$medium-screen-and-smaller} {
			&::before,
			&::after {
				display: none !important;
			}
		}
	}

	/*
	* =============================
	* Hero
	* =============================
	*/
	.boost-your-testosterone.hero {
		background-color: colors.$color-white;
		padding: fonts.rem(40px) fonts.rem(64px);
		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(16px) fonts.rem(32px) fonts.rem(40px);
			flex-direction: column;
			gap: fonts.rem(24px);
		}
		@media #{layout.$small-screen-only} {
			padding-inline: fonts.rem(16px);
		}

		.container.grid {
			gap: fonts.rem(64px);
			grid-template-columns: 600px 1fr;
			@media #{layout.$medium-screen-and-smaller} {
				grid-template-columns: 1fr;
				gap: fonts.rem(24px);
			}
		}

		.container {
			@media #{layout.$medium-screen-and-smaller} {
				display: flex;
				flex-direction: column;
				gap: fonts.rem(24px);
			}
		}

		// Left column — image
		.media-wrapper {
			padding: 0;
			display: flex;
			align-items: center;
			background-color: colors.$color-white;
			@media #{layout.$medium-screen-and-smaller} {
				order: 1;
			}

			.media-block {
				width: 600px;
				aspect-ratio: 1 / 1;
				@media #{layout.$medium-screen-and-smaller} {
					width: 100%;
					max-width: fonts.rem(600px);
					height: auto;
					margin-left: auto;
					margin-right: auto;
				}

				video {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
			}
		}

		// Right column — content
		.content-wrapper {
			padding: 0;
			display: flex;
			flex-direction: column;
			justify-content: center;
			gap: fonts.rem(40px);
			@media #{layout.$medium-screen-and-smaller} {
				order: 2;
				gap: fonts.rem(24px);
			}

			// Title
			.title-block h2 {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;
				max-width: 576px;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
					max-width: none;
				}
			}

			// List items
			.content-block {
				ul {
					list-style: none;
					margin: 0;
					padding: 0;
					display: flex;
					flex-direction: column;
					gap: fonts.rem(16px);
					@media #{layout.$medium-screen-and-smaller} {
						gap: fonts.rem(12px);
					}
				}

				li {
					border-left: 2px solid rgba(96, 91, 82, 0.2);
					padding-left: fonts.rem(12px);
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(22px);
					line-height: 1.1;
					letter-spacing: -0.44px;
					color: colors.$color-black;
					@media #{layout.$medium-screen-and-smaller} {
						font-size: fonts.rem(18px);
						letter-spacing: -0.36px;
						padding-left: fonts.rem(8px);
					}
				}
			}

			// CTA block
			.cta-block {
				display: flex;
				flex-direction: column;
				gap: fonts.rem(8px);
				width: 100%;

				.cta-wrapper {
					width: 100%;
				}

				a {
					width: 100%;
					height: 48px;
					border-radius: 2px;
					padding: 0 fonts.rem(48px);
					box-sizing: border-box;
				}
			}

			// Badges — pull up to 8px below CTA (40px gap - 32px = 8px)
			.badges-wrapper {
				margin-top: fonts.rem(-32px);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: center;
				gap: fonts.rem(10px);
				// Adjust for 24px gap (24px - 16px = 8px)
				@media #{layout.$medium-screen-and-smaller} {
					margin-top: fonts.rem(-16px);
				}

				.badge {
					display: flex;
					align-items: center;
					height: 20px;

					img {
						width: auto;
						height: 24px;
					}

					span {
						font-family: fonts.$DM-Sans;
						font-weight: 400;
						font-size: fonts.rem(14px);
						line-height: 1.4;
						letter-spacing: -0.28px;
						color: colors.$color-gray;
						text-align: center;
					}
				}
			}
		}
	}

	/*
	* =============================
	* Marquee / Trustpilot Ratings
	* =============================
	*/
	.marquee.trustpilot-ratings {
		background-color: colors.$color-white;

		.container {
			display: flex;
			align-items: center;
			gap: fonts.rem(16px);
			padding: fonts.rem(16px);
			@media #{layout.$medium-screen-and-smaller} {
				flex-direction: column;
				padding: fonts.rem(16px) 0;
			}
		}

		.trustpilot-wrapper {
			flex-shrink: 0;
			@media only screen and (max-width: 445px) {
				min-width: unset;
			}
		}

		.trustpilot-static {
			display: flex;
			align-items: center;
			gap: fonts.rem(8px);
			text-decoration: none;
			color: #191919;
			white-space: nowrap;

			.tp-text {
				font-weight: 700;
				font-size: fonts.rem(12px);
			}

			.tp-stars {
				height: 14px;
			}

			.tp-count {
				font-size: fonts.rem(12px);
			}

			.tp-brandmark {
				width: auto;
				height: 16px;
			}

			@media only screen and (max-width: 445px) {
				flex-wrap: wrap;
				justify-content: center;
				gap: fonts.rem(4px) fonts.rem(8px);
			}
		}

		.reviews-wrapper {
			flex: 1 0 0;
			overflow: hidden;
			position: relative;
			@media #{layout.$medium-screen-and-smaller} {
				flex: 0 0 auto;
				width: 100%;
			}

			// Fade edges
			&::before,
			&::after {
				content: '';
				position: absolute;
				top: 0;
				bottom: 0;
				width: 78px;
				z-index: 1;
				pointer-events: none;
			}

			&::before {
				left: 0;
				background: linear-gradient(to right, colors.$color-white, transparent);
			}

			&::after {
				right: 0;
				background: linear-gradient(to left, colors.$color-white, transparent);
			}
		}

		.reviews-marquee {
			display: flex;
			width: max-content;
			will-change: transform;
			animation: marquee-scroll calc(var(--review-count, 4) * 3s) linear infinite;
		}

		.reviews-set {
			display: flex;
			flex-shrink: 0;
		}

		.review-item {
			display: flex;
			align-items: center;
			gap: fonts.rem(8px);
			flex-shrink: 0;
			white-space: nowrap;
			margin-right: fonts.rem(16px);

			.quote-content {
				font-family: fonts.$DM-Sans;
				font-weight: 400;
				font-size: fonts.rem(16px);
				line-height: 1.4;
				letter-spacing: -0.16px;
				color: colors.$color-black;
			}

			.reviewer-details {
				font-family: fonts.$DM-Sans;
				font-weight: 400;
				font-size: fonts.rem(16px);
				line-height: 1.4;
				letter-spacing: -0.16px;
				color: colors.$color-gray;
			}
		}
	}

	/*
	* =============================
	* How It Works / Social Videos
	* =============================
	*/
	.how-it-works.social-videos {
		padding: fonts.rem(64px) 0;
		position: relative;
		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) 0;
		}

		&.extended-center-border-below::after {
			left: 50%;
		}

		&::before {
			@media #{layout.$medium-screen-and-smaller} {
				display: none;
			}
		}

		.container {
			position: relative;
			z-index: 1;
			background-color: colors.$color-white;
			border-radius: 20px;
			padding: fonts.rem(32px) 0;
			display: flex;
			flex-direction: column;
			gap: fonts.rem(32px);
			@media #{layout.$medium-screen-and-smaller} {
				padding: 0;
				border-radius: 0;
				background-color: transparent;
			}
		}

		// Title block
		.title-wrapper {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(16px);
			align-items: center;
			text-align: center;
			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(8px);
			}

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
				}
			}

			.subtitle {
				font-family: fonts.$DM-Sans;
				font-weight: 500;
				font-size: fonts.rem(22px);
				line-height: 1;
				letter-spacing: -0.44px;
				color: colors.$color-black;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(18px);
					letter-spacing: -0.36px;
				}
			}
		}

		// Video cards row
		.carousel-wrapper {
			padding: 0;
			display: flex;
			gap: fonts.rem(24px);
			align-items: center;
			justify-content: center;
			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(8px);
				justify-content: flex-start;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;

				&::-webkit-scrollbar {
					display: none;
				}
			}
			.review-video-item:first-child {
				margin-left: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-left: fonts.rem(16px);
				}
			}
			.review-video-item:last-child {
				margin-right: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-right: fonts.rem(16px);
				}
			}
		}

		.review-video-item {
			width: 270px;
			height: 480px;
			border-radius: 20px;
			overflow: hidden;
			position: relative;
			background-color: colors.$color-gray-light;
			flex-shrink: 0;
			cursor: pointer;

			.thumbnail-wrapper {
				position: absolute;
				inset: 0;
				z-index: 1;
				transition: opacity 0.3s ease;

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
			}

			.video-wrapper {
				position: absolute;
				inset: 0;

				video {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
			}

		.play-button {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			z-index: 2;
			width: 72px;
			height: 72px;
			border-radius: 50%;
			border: none;
			background: rgba(255, 255, 255, 0.75);
			color: rgba(0, 0, 0, 0.75);
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: opacity 0.3s ease, background 0.2s ease;
			pointer-events: none;

			svg {
				margin-left: 3px;
				fill: rgba(0, 0, 0, 0.4);
			}

			&:hover {
				background: rgba(255, 255, 255, 0.9);
			}
		}

		&.playing .play-button {
			opacity: 0;
		}

		.mute-toggle {
			position: absolute;
			bottom: 12px;
			right: 12px;
			z-index: 3;
			width: 36px;
			height: 36px;
			border-radius: 50%;
			border: none;
			background: rgba(0, 0, 0, 0.55);
			color: colors.$color-white;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			opacity: 0;
			transition: opacity 0.3s ease, background 0.2s ease;
			padding: 0;

			&:hover {
				background: rgba(0, 0, 0, 0.75);
			}

			.icon-unmuted {
				display: none;
			}
		}

		&.playing .thumbnail-wrapper {
			opacity: 0;
		}

		&.playing .mute-toggle {
			opacity: 1;
		}

		&.unmuted .mute-toggle {
			.icon-muted {
				display: none;
			}
			.icon-unmuted {
				display: block;
			}
		}
	}
	}

	/*
	* =============================
	* Benefits Timeline
	* =============================
	*/
	.benefits-timeline {
		background-color: colors.$color-white;
		padding: fonts.rem(32px) 0;
		position: relative;
		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) 0;
		}

		.container {
			position: relative;
			z-index: 1;
			background-color: colors.$color-white;
			display: flex;
			flex-direction: column;
			gap: fonts.rem(32px);
			padding: fonts.rem(32px) 0 fonts.rem(80px);
			@media #{layout.$medium-screen-and-smaller} {
				padding: 0;
				gap: fonts.rem(40px);
				padding: 0;
				background-color: transparent;
			}
		}

		// Title
		.title-block {
			text-align: center;

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
				}
			}
		}

		// Cards row
		.timeline-wrapper {
			padding: 0;
		}

		.benefits-timeline-carousel {
			display: flex;
			justify-content: center;
			align-items: stretch; // all cards same height so dividers align
			width: 100%;
			@media #{layout.$medium-screen-and-smaller} {
				justify-content: flex-start;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;

				&::-webkit-scrollbar {
					display: none;
				}
			}
		}

		// Individual card
		// Image has fixed height so the divider line stays at a constant
		// vertical position across all cards during expand/collapse.
		.timeline-card {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(8px);
			width: 250px;
			flex-shrink: 0;
			opacity: 0.8;
			cursor: pointer;
			transition: width 0.4s ease, opacity 0.4s ease;
			@media #{layout.$medium-screen-and-smaller} {
				max-width: 325px;
				width: 100vw;
				opacity: 1;
				cursor: default;
				transition: none;
			}
			&:first-child {
				margin-left: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-left: fonts.rem(16px);
				}
				@media only screen and (max-width: 315px) {
					margin-left: fonts.rem(8px);
				}
			}
			&:last-child {
				margin-right: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-right: fonts.rem(16px);
				}
				@media only screen and (max-width: 315px) {
					margin-right: fonts.rem(8px);
				}
			}

			// Image — fixed height, image sits at the bottom
			.image-wrapper {
				padding: 0 fonts.rem(8px);
				height: 296px;
				display: flex;
				align-items: flex-end;
				@media #{layout.$medium-screen-and-smaller} {
					height: auto;
					align-items: stretch;
				}

				img {
					width: 100%;
					aspect-ratio: 1 / 1;
					object-fit: cover;
					border-radius: 15px;
					display: block;
					transition: border-radius 0.4s ease;
					@media #{layout.$medium-screen-and-smaller} {
						border-radius: 20px;
					}
				}
			}

			// Divider: dot + line — the anchored midline
			.divider-wrapper {
				display: flex;
				align-items: center;
				gap: fonts.rem(8px);
				padding-bottom: fonts.rem(8px);
				padding-left: fonts.rem(8px);

				.dot {
					width: 12px;
					height: 12px;
					border-radius: 8px;
					border: 3px solid #20C475;
					background: colors.$color-white;
					flex-shrink: 0;
					box-sizing: border-box;
					// @media #{layout.$medium-screen-and-smaller} {
					// 	border-color: colors.$color-gray;
					// 	background: #D9D9D9;
					// }
				}

				.line {
					flex: 1;
					height: 1px;
					background-color: colors.$color-gray;
				}
			}

			// Content: day, heading, body
			.content-wrapper {
				display: flex;
				flex-direction: column;
				gap: fonts.rem(8px);
				padding: 0 fonts.rem(8px);

				.day {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.1;
					letter-spacing: -0.28px;
					color: colors.$color-black;
				}

				.heading {
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(18px);
					line-height: 1.1;
					letter-spacing: -0.36px;
					color: colors.$color-black;
					max-height: 0;
					overflow: hidden;
					opacity: 0;
					transition: max-height 0.4s ease, opacity 0.3s ease;
					@media #{layout.$medium-screen-and-smaller} {
						max-height: none;
						overflow: visible;
						opacity: 1;
					}
				}

				.body {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.4;
					letter-spacing: -0.14px;
					color: colors.$color-black;
					max-height: 0;
					overflow: hidden;
					opacity: 0;
					transition: max-height 0.4s ease, opacity 0.3s ease;
					@media #{layout.$medium-screen-and-smaller} {
						max-height: none;
						overflow: visible;
						opacity: 1;
					}
				}
			}

			// Active state
			&.active {
				width: 312px;
				opacity: 1;
				@media #{layout.$medium-screen-and-smaller} {
					max-width: 325px;
					width: 100vw;
				}

				.image-wrapper img {
					border-radius: 22.5px;
					@media #{layout.$medium-screen-and-smaller} {
						border-radius: 20px;
					}
				}

				.content-wrapper {
					.heading {
						max-height: 100px;
						opacity: 1;
					}

					.body {
						max-height: 300px;
						opacity: 1;
					}
				}
			}
		}
	}

	/*
	* =============================
	* Proven Benefits of TRT
	* =============================
	*/
	.proven-benefits {
		background-color: colors.$color-white;
		position: relative;
		@media #{layout.$medium-screen-and-smaller} {
			grid-template-columns: 1fr;
		}

		&.extended-center-border-above::before {
			left: calc(50% - 1px);
		}

		// Left column — image
		.container {
			flex: 1 0 0;
			position: relative;
			z-index: 1;
			@media #{layout.$medium-screen-and-smaller} {
				flex: 0 0 auto;
				gap: 0;
			}
		}

		.media-wrapper {
			height: 100%;

			.media-block {
				height: 100%;
				@media #{layout.$medium-screen-and-smaller} {
					height: auto;
					aspect-ratio: 1 / 1;
				}

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
					display: block;
				}
			}
		}

		// Right column — content
		.content-wrapper {
			flex: 1 0 0;
			background-color: colors.$color-white;
			padding: fonts.rem(64px);
			display: flex;
			flex-direction: column;
			gap: fonts.rem(24px);
			justify-content: center;
			position: relative;
			z-index: 1;
			@media #{layout.$medium-screen-and-smaller} {
				flex: 0 0 auto;
				padding: fonts.rem(24px) fonts.rem(32px) fonts.rem(40px);
				gap: fonts.rem(32px);
			}
			@media #{layout.$small-screen-only} {
				padding: fonts.rem(24px) fonts.rem(16px) fonts.rem(40px);
			}

			.title-block .title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;
				max-width: 576px;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
					max-width: none;
				}
			}
		}

		// Benefits grid — 2 columns, 3 rows
		.grid-block {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: fonts.rem(40px) fonts.rem(32px);
			padding: fonts.rem(32px) 0;
