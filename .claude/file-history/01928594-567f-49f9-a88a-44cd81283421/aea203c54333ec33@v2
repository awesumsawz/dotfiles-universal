		.benefits-item {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(12px);
			@media #{layout.$medium-screen-and-smaller} {
				gap: 0;
			}

			.icon-wrapper {
				width: fit-content;
				display: flex;
				align-items: center;
				justify-content: center;
				@media #{layout.$medium-screen-and-smaller} {
					margin-bottom: fonts.rem(8px);
				}

				img {
