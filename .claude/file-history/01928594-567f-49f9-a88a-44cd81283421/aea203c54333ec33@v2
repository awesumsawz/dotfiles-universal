			.item-content {
				display: flex;
				flex-direction: column;
				gap: fonts.rem(8px);
				align-items: center;
				text-align: center;

				.item-title {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(28px);
					line-height: 1.1;
					letter-spacing: -0.56px;
					color: colors.$color-black;
				}

				.item-description {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(16px);
					line-height: 1.4;
					letter-spacing: -0.16px;
					color: colors.$color-black;
				}
