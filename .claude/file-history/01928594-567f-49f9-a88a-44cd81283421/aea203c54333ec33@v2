			flex-basis: 100%;
			display: flex;
			justify-content: center;
			@media #{layout.$small-screen-only} {
				flex-basis: unset;
				width: 100%;
			}

			.cta-wrapper {
				width: 366px;
			}

			a {
				width: 100%;
				height: 48px;
				border-radius: 2px;
				padding: 0 fonts.rem(48px);
				box-sizing: border-box;
				@media #{layout.$small-screen-only} {
					padding: 0;
				}
