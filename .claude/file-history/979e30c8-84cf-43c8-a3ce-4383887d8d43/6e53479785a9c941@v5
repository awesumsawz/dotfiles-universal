					height: fonts.rem(48px);
					background-color: colors.$color-yellow;
					border: 1px solid rgba(14, 11, 32, 0.2);
					border-radius: 2px;
					padding: 0 fonts.rem(48px);
					color: colors.$color-black;
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(16px);
					line-height: 1.3;
					letter-spacing: -0.32px;
					text-decoration: none;
					cursor: pointer;
					box-sizing: border-box;

					&:hover {
						background-color: colors.$color-yellow-dark;
					}
				}

				.badges-wrapper {
					display: flex;
					flex-wrap: wrap;
					align-items: center;
					justify-content: center;
					gap: fonts.rem(10px);

					.badge {
						display: flex;
						align-items: center;
						gap: fonts.rem(4px);
						height: 20px;

						img {
							width: auto;
							height: 24px;
						}

						span {
							font-family: fonts.$DM-Sans;
							font-weight: 400;
							font-size: fonts.rem(14px);
							line-height: 1.4;
							letter-spacing: -0.28px;
							color: colors.$color-gray;
						}
					}
				}
			}
		}

		// FAQ accordion
		.faq-block {
			margin-top: fonts.rem(40px);

			.faq-item {
				border-bottom: 1px solid rgba(96, 91, 82, 0.2);

				&:first-child {
					border-top: 1px solid rgba(96, 91, 82, 0.2);
				}
			}

			.faq-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: fonts.rem(12px) 0;
				cursor: pointer;
				gap: fonts.rem(16px);

				.faq-question {
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(18px);
					line-height: 1.1;
					letter-spacing: -0.36px;
					color: #202020;
				}

				.faq-icon {
					display: flex;
					align-items: center;
					justify-content: center;
					width: 24px;
					height: 24px;
					flex-shrink: 0;
					position: relative;

					.icon-line {
						position: absolute;
						background-color: colors.$color-black;
						transition: transform 0.3s ease;
					}

					.line-horizontal {
						width: 24px;
						height: 1px;
					}

					.line-vertical {
						width: 1px;
						height: 24px;
					}
				}
			}

			.faq-content {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.4s ease;

				.faq-item-answer {
					padding: 0 0 fonts.rem(16px);
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.4;
					letter-spacing: -0.14px;
					color: colors.$color-black;
				}
			}

			.faq-item.active {
				.faq-icon .line-vertical {
					transform: rotate(90deg);
				}

				.faq-content {
					max-height: 500px;
				}
			}
		}
	}

	/*
	 * =============================
	 * Disease Monitor Section
	 * =============================
	 */
	.disease-monitor {
		background-color: colors.$color-white;
		padding: fonts.rem(64px);

		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) fonts.rem(32px);
		}

		@media #{layout.$small-screen-and-smaller} {
			padding: fonts.rem(32px) fonts.rem(16px);
		}

		// Rounded inner card (clips the wide parallax rows)
		.section-inner {
			background: rgba(241, 240, 239, 0.85);
			border-radius: fonts.rem(20px);
			overflow: hidden;
			padding: fonts.rem(64px) 0 fonts.rem(35px);
			box-shadow:
				0px 82px 33px rgba(0, 0, 0, 0.01),
				0px 46px 28px rgba(0, 0, 0, 0.03),
				0px 20px 20px rgba(0, 0, 0, 0.05),
				0px 5px 11px rgba(0, 0, 0, 0.06);

			@media #{layout.$medium-screen-and-smaller} {
				padding: fonts.rem(32px) 0;
			}
		}

		// Title + badges
		.title-block {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(8px);
			align-items: center;
			text-align: center;
			padding-inline: fonts.rem(64px);
			margin-bottom: fonts.rem(35px);

			@media #{layout.$medium-screen-and-smaller} {
				padding-inline: fonts.rem(32px);
				margin-bottom: fonts.rem(24px);
				gap: fonts.rem(12px);
			}

			@media #{layout.$small-screen-and-smaller} {
				padding-inline: fonts.rem(16px);
			}

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;

				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(29px);
					line-height: 0.96;
					letter-spacing: -0.29px;
				}
			}
		}

		.badges-row {
			display: flex;
			align-items: center;
			gap: fonts.rem(16px);
			justify-content: center;
			flex-wrap: wrap;

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(10px);
			}

			.check-badge {
				display: flex;
				align-items: center;
				height: 20px;

				img {
					width: auto;
					height: 24px;
				}

				span {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.4;
					letter-spacing: -0.14px;
					color: colors.$color-gray;
					white-space: nowrap;
				}
			}
		}

		// Disease tag parallax rows
		.tags-area {
			position: relative;
			min-height: fonts.rem(168px); // Ensures desktop float card (168px tall) is fully visible
			display: flex;
			justify-content: center;
			align-items: center;
			@media #{layout.$medium-screen-and-smaller} {
				min-height: fonts.rem(78px);
			}
		}

		.disease-list {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(12px);

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(8px);
			}
		}

		.disease-row-wrapper {
			overflow: hidden;
			width: 100%;
		}

		.disease-row-container {
			overflow: hidden;
		}

		.disease-row-list {
			display: flex;
			width: max-content;
			white-space: nowrap;
			will-change: transform;
			gap: fonts.rem(12px);
			animation: marquee-scroll 50s linear infinite;

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(8px);
			}
		}

		.row-two .disease-row-list {
			animation-direction: reverse;
		}

		.disease-item {
			display: inline-flex;
			align-items: center;
			padding: fonts.rem(11px) fonts.rem(16px);
			background: rgba(255, 255, 255, 0.85);
			backdrop-filter: blur(7.5px);
			-webkit-backdrop-filter: blur(7.5px);
			border-radius: 5px;
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: fonts.rem(22px);
			line-height: 1.1;
			letter-spacing: -0.44px;
			color: colors.$color-black;
			white-space: nowrap;
			flex-shrink: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(18px);
				letter-spacing: -0.36px;
				padding: fonts.rem(8px) fonts.rem(12px);
			}
		}

		// Desktop: card floats centered over the disease rows (modal style)
		.biomarker-card-float {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			z-index: 10;

			img {
				display: block;
				width: fonts.rem(243px);
				height: fonts.rem(168px);
			}
		}

		// Mobile: card sits as a standalone block above the disease rows
		.biomarker-card-standalone {
			display: none;
			justify-content: center;
			padding: 0 fonts.rem(32px);
			margin-bottom: fonts.rem(24px);

			@media #{layout.$medium-screen-and-smaller} {
				display: flex;
			}

			@media #{layout.$small-screen-and-smaller} {
				padding: 0 fonts.rem(16px);
			}

			img {
				display: block;
				width: 100%;
				max-width: fonts.rem(330px);
				height: fonts.rem(229px);
			}
		}
	}

	/*
	 * =============================
	 * Care Callout
	 * =============================
	 */
	.care-callout {
		background-color: colors.$color-white;

		.container {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(64px);
			padding: fonts.rem(64px);

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(48px);
				padding: fonts.rem(48px) fonts.rem(24px);
			}
		}

		// ——— Tout block ———
		.tout-block {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: fonts.rem(64px);
			align-items: center;

			@media #{layout.$medium-screen-and-smaller} {
				grid-template-columns: 1fr;
				gap: fonts.rem(32px);
			}
		}

		.tout-content {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(24px);

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(20px);
			}
		}

		.title {
			font-family: fonts.$STIX-Two-Text;
			font-weight: 400;
			font-size: fonts.rem(42px);
			line-height: 1;
			letter-spacing: -0.84px;
			color: colors.$color-black;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(29px);
				letter-spacing: -0.58px;
			}
		}

		.stars-wrapper {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: fonts.rem(8px);

			img {
				width: fonts.rem(90px);
				height: auto;
			}

			span {
				font-family: fonts.$DM-Sans;
				font-size: fonts.rem(14px);
				font-weight: 400;
				line-height: 1.4;
				color: colors.$color-black;
			}
		}

		.featured-review {
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: fonts.rem(12px);

			p {
				font-family: fonts.$DM-Sans;
				font-size: fonts.rem(18px);
				font-weight: 400;
				line-height: 1.5;
				letter-spacing: -0.18px;
				color: colors.$color-black;
				margin: 0;

				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(16px);
				}
			}

			footer {
				display: flex;
				flex-direction: row;
				align-items: center;
				gap: fonts.rem(8px);

				.name {
					font-family: fonts.$DM-Sans;
					font-size: fonts.rem(14px);
					font-weight: 700;
					color: colors.$color-black;
				}

				.label {
					font-family: fonts.$DM-Sans;
					font-size: fonts.rem(14px);
					font-weight: 400;
					color: rgba(96, 91, 82, 0.6);

					&::before {
						content: '·';
						margin-right: fonts.rem(8px);
					}
				}
			}
		}

		.cta-button {
			display: flex;
			align-items: center;
			justify-content: center;
			height: fonts.rem(48px);
			padding: 0 fonts.rem(32px);
			background-color: colors.$color-yellow;
			color: colors.$color-black;
			font-family: fonts.$DM-Sans;
			font-size: fonts.rem(16px);
			font-weight: 500;
			letter-spacing: -0.16px;
			border-radius: 2px;
			text-decoration: none;
			transition: background-color 0.2s ease;
			align-self: flex-start;

			&:hover {
				background-color: colors.$color-yellow-dark;
			}

			@media #{layout.$medium-screen-and-smaller} {
				width: 100%;
				align-self: stretch;
			}
		}

		// ——— Doctor grid ———
		.doctor-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: fonts.rem(12px);

			@media #{layout.$medium-screen-and-smaller} {
				// 4 tiles in a single row strip on mobile
				grid-template-columns: repeat(4, 1fr);
				gap: fonts.rem(8px);
			}
		}

		.doctor-tile {
			border-radius: fonts.rem(20px);
			overflow: hidden;
			aspect-ratio: 244 / 282;

			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
		}

		// ——— Carousel block ———
		.carousel-block {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(32px);
		}

		.care-callout-carousel {
			overflow-x: hidden;
			overflow-y: visible;
			width: 100%;

			// Slick core inline
			.slick-list {
				overflow: hidden;
				display: block;
				margin: 0;
				padding: 0;

				&.dragging img { pointer-events: none; }
			}

			.slick-track {
				display: flex !important;
				align-items: stretch;
				margin: auto;
			}

			.slick-slide {
				height: inherit;

				> div { height: 100%; }

				// Override global [aria-hidden="true"] { display: none !important }
				// Slick sets aria-hidden on off-screen slides; visual clipping is
				// handled by .slick-list overflow:hidden, not display:none.
				&[aria-hidden="true"] {
					display: block !important;
				}
			}

			.slick-initialized .review-card {
				display: flex !important;
			}
		}

		.review-card {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(16px);
			padding: fonts.rem(24px);
			background-color: #f1f0ef;
			border-radius: fonts.rem(20px);
			margin-inline: fonts.rem(8px);
			height: 100%;

			@media #{layout.$medium-screen-and-smaller} {
				margin-inline: fonts.rem(6px);
			}
		}

		.review-rating img {
			height: fonts.rem(16px);
			width: auto;
		}

		.review-title {
			font-family: fonts.$DM-Sans;
			font-size: fonts.rem(18px);
			font-weight: 700;
			line-height: 1;
			letter-spacing: -0.36px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(16px);
			}
		}

		.review-text {
			font-family: fonts.$DM-Sans;
			font-size: fonts.rem(16px);
			font-weight: 400;
			line-height: 1.5;
			letter-spacing: -0.16px;
			color: colors.$color-black;
			margin: 0;
			flex: 1;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(14px);
			}
		}

		.review-attribution {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: fonts.rem(8px);

			.name {
				font-family: fonts.$DM-Sans;
				font-size: fonts.rem(14px);
				font-weight: 700;
				color: colors.$color-black;
			}

			.label {
				font-family: fonts.$DM-Sans;
				font-size: fonts.rem(14px);
				font-weight: 400;
				color: rgba(96, 91, 82, 0.6);

				&::before {
					content: '·';
					margin-right: fonts.rem(8px);
				}
			}
		}

		// ——— Navigation ———
		.care-callout-navigation {
			margin-top: 0;
		}

		.care-callout-dots {
			display: flex;
			align-items: center;
			justify-content: center;
			min-width: fonts.rem(84px);

			.slick-dots {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex !important;
				align-items: center;
				gap: fonts.rem(8px);
				position: static;
				bottom: auto;

				li {
					margin: 0;
					width: auto;
					height: auto;
					line-height: 0;

					button {
						width: 12px;
						height: 12px;
						border-radius: 50%;
						background-color: rgba(96, 91, 82, 0.3);
						border: none;
						padding: 0;
						cursor: pointer;
						font-size: 0;
						line-height: 0;
						transition: background-color 0.3s ease;

						&::before { display: none; }
					}

					&.slick-active button {
						background-color: colors.$color-black;
					}
				}
			}
		}
	}

	/*
	 * =============================
	 * Guide Section
	 * =============================
	 */
	.guide {
		background-color: colors.$color-white;

		&::after {
			bottom: 0;
		}

		.container {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: fonts.rem(40px);
			padding: fonts.rem(64px);

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(32px);
				padding: fonts.rem(48px) 0;
			}
		}

		.title {
			font-family: fonts.$STIX-Two-Text;
			font-weight: 400;
			font-size: fonts.rem(54px);
			line-height: 1;
			letter-spacing: -1.08px;
			color: colors.$color-black;
			text-align: center;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(36px);
				letter-spacing: -0.72px;
				padding: 0 fonts.rem(24px);
			}
		}

		// ——— Scrollable cards row ———
		.guide-cards {
			display: flex;
			flex-direction: row;
			gap: fonts.rem(24px);
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			cursor: grab;
			width: 100%;

			&::-webkit-scrollbar { display: none; }
			&:active { cursor: grabbing; }

			@media #{layout.$medium-screen-and-smaller} {
				gap: fonts.rem(16px);
				padding: 0 fonts.rem(24px);
			}
		}

		.guide-card {
			flex: 0 0 fonts.rem(328px);
			scroll-snap-align: start;
			display: flex;
			flex-direction: column;
			gap: fonts.rem(16px);

			@media #{layout.$medium-screen-and-smaller} {
				flex: 0 0 fonts.rem(272px);
			}

			@media #{layout.$small-screen-and-smaller} {
				flex: 0 0 calc(85vw);
			}
		}

		.guide-card-image {
			aspect-ratio: 1 / 1;
			border-radius: fonts.rem(21px);
			overflow: hidden;
			position: relative;

			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				// If image fails to load, bg-color from inline style shows through
			}
		}

		.guide-card-content {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(8px);
		}

		.card-title {
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: fonts.rem(22px);
			line-height: 1.1;
			letter-spacing: -0.44px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(18px);
				letter-spacing: -0.36px;
			}
		}

		.card-desc {
			font-family: fonts.$DM-Sans;
			font-weight: 400;
			font-size: fonts.rem(16px);
			line-height: 1.4;
			letter-spacing: -0.16px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(14px);
				letter-spacing: -0.14px;
			}
		}

		// ——— CTA ———
		.cta-button {
			display: flex;
			align-items: center;
			justify-content: center;
			height: fonts.rem(48px);
			width: fonts.rem(366px);
			background-color: colors.$color-yellow;
			color: colors.$color-black;
			font-family: fonts.$DM-Sans;
			font-size: fonts.rem(16px);
			font-weight: 500;
			letter-spacing: -0.32px;
			border-radius: 2px;
			border: 1px solid rgba(14, 11, 32, 0.2);
			text-decoration: none;
			transition: background-color 0.2s ease;

			&:hover {
				background-color: colors.$color-yellow-dark;
			}

			@media #{layout.$medium-screen-and-smaller} {
				width: calc(100% - fonts.rem(48px));
			}
		}
	}
}

@keyframes marquee-scroll {
	from {
		transform: translateX(0);
	}
	to {
		transform: translateX(var(--marquee-offset, -50%));
	}
}
