/**
 * OPT Longevity
 * Page-specific styles for page-opt-longevity.php
 *
 * Desktop-first: base styles target desktop (1440px).
 * Tablet/mobile overrides via $medium-screen-and-smaller (max-width: 1024px).
 * Mobile-only refinements via $small-screen-and-smaller (max-width: 600px).
 */
@use '../variables/colors' as colors;
@use '../variables/fonts' as fonts;
@use '../variables/layout' as layout;

$full-width-elements: '.linkbar, .navbar, .site-footer, .longevity-hero';

.opt-longevity {
	> section:not(#{$full-width-elements}) > .container {
		max-width: 1440px;
		margin: 0 auto;
	}
	.extended-center-border-above::before {
		left: calc(50% - 1px);
		@media #{layout.$medium-screen-and-smaller} {
			display: none;
		}
	}
	.extended-center-border-below::after {
		@media #{layout.$medium-screen-and-smaller} {
			display: none;
		}
	}

	/*
	 * =============================
	 * Hero Section
	 * =============================
	 */
	.longevity-hero {
		.container {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 40px;
			padding: 40px 0 64px;
			@media #{layout.$medium-screen-and-smaller} {
				padding: 40px 0;
			}
			@media #{layout.$small-screen-and-smaller} {
				padding: 40px 0;
			}
		}
		/*
		* Gallery — Faux 3D horizontal scroller
		* Inspired by https://codepen.io/jh3y/pen/gOeXgXv
		* Uses white pseudo-element ellipses at top/bottom to create a gentle
		* curved barrel clip, matching the Figma's large ellipse overlays.
		*/
		.gallery-wrapper {
			--gallery-height: 225px;
			position: relative;
			width: 100%;
			overflow: hidden;

			// Top and bottom curved clips — white ellipses that overlay the gallery edges
			&::before,
			&::after {
				content: '';
				position: absolute;
				left: -10%;
				width: 120%;
				height: 80px;
				z-index: 1;
				pointer-events: none;
				background: colors.$color-white;
				border-radius: 50%;
			}

			&::before {
				top: -60px;
			}

			&::after {
				bottom: -60px;
			}

			@media #{layout.$medium-screen-and-smaller} {
				--gallery-height: 180px;

				&::before,
				&::after {
					height: 60px;
				}

				&::before {
					top: -44px;
				}

				&::after {
					bottom: -44px;
				}
			}

			@media #{layout.$small-screen-and-smaller} {
				--gallery-height: 126px;

				&::before,
				&::after {
					height: 50px;
				}

				&::before {
					top: -36px;
				}

				&::after {
					bottom: -36px;
				}
			}
		}

		.gallery-scroller {
			display: flex;
			gap: 32px;
			height: var(--gallery-height);
			overflow-x: auto;
			overflow-y: hidden;
			scrollbar-width: none;
			scroll-snap-type: x proximity;

			&::-webkit-scrollbar {
				display: none;
			}

			@media #{layout.$medium-screen-and-smaller} {
				gap: 24px;
			}

			@media #{layout.$small-screen-and-smaller} {
				gap: 18px;
			}
		}

		.gallery-item {
			flex-shrink: 0;
			height: 100%;
			scroll-snap-align: center;

			img {
				height: 100%;
				width: auto;
				object-fit: cover;
				display: block;
			}
		}

		/*
		* Content — Text, CTA, badges
		*/
		.content-wrapper {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 24px;
			max-width: 900px;
			width: 100%;
			padding: 0 64px;
			text-align: center;

			@media #{layout.$medium-screen-and-smaller} {
				padding: 0 32px;
			}

			@media #{layout.$small-screen-and-smaller} {
				padding: 0 16px;
			}
		}

		.title-block {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.title {
			font-family: fonts.$STIX-Two-Text;
			font-weight: 400;
			font-size: 54px;
			line-height: 1;
			letter-spacing: -1.08px;
			color: colors.$color-black;
			max-width: 576px;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: 36px;
				letter-spacing: -0.72px;
				max-width: 100%;
			}
		}

		.content-block {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 20px;
			width: 100%;
		}

		.subtitle {
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: 22px;
			line-height: 1.1;
			letter-spacing: -0.44px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: 18px;
				letter-spacing: -0.36px;
			}
		}

		.price-line {
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: 22px;
			line-height: 1.1;
			letter-spacing: -0.44px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: 18px;
				letter-spacing: -0.36px;
			}
		}

		.cta-block {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 8px;
			width: 100%;
		}

		.cta-button {
			display: flex;
			align-items: center;
			justify-content: center;
			background-color: colors.$color-yellow;
			border: 1px solid colors.$color-gray-medium-transparent;
			color: colors.$color-black;
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: 16px;
			line-height: 1.3;
			letter-spacing: -0.32px;
			height: 48px;
			padding: 0 48px;
			border-radius: 2px;
			text-decoration: none;
			cursor: pointer;
			width: 100%;

			&:hover {
				background-color: colors.$color-yellow-dark;
			}

			@media #{layout.$small-screen-and-smaller} {
				padding: 0 24px;
			}
		}

		.badges-wrapper {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 10px;
		}

		.badge {
			display: flex;
			align-items: center;
			height: 20px;

			img {
				width: 24px;
				height: 24px;
				flex-shrink: 0;
			}

			span {
				font-family: fonts.$DM-Sans;
				font-weight: 400;
				font-size: 14px;
				line-height: 1.4;
				letter-spacing: -0.28px;
				color: colors.$color-gray;
				white-space: nowrap;
			}
		}
	}
	

	/*
	 * =============================
	 * Marquee / Trustpilot Ratings
	 * =============================
	 */
	.marquee.trustpilot-ratings {
		background-color: colors.$color-white;

		.container {
			display: flex;
			align-items: center;
			gap: fonts.rem(16px);
			padding: fonts.rem(16px);
			@media #{layout.$medium-screen-and-smaller} {
				flex-direction: column;
				padding: fonts.rem(16px) 0;
			}
		}

		.trustpilot-wrapper {
			flex-shrink: 0;
			@media only screen and (max-width: 445px) {
				min-width: unset;
			}
		}

		.trustpilot-static {
			display: flex;
			align-items: center;
			gap: fonts.rem(8px);
			text-decoration: none;
			color: #191919;
			white-space: nowrap;

			.tp-text {
				font-weight: 700;
				font-size: fonts.rem(12px);
			}

			.tp-stars {
				height: 14px;
			}

			.tp-count {
				font-size: fonts.rem(12px);
			}

			.tp-brandmark {
				width: auto;
				height: 16px;
			}

			@media only screen and (max-width: 445px) {
				flex-wrap: wrap;
				justify-content: center;
				gap: fonts.rem(4px) fonts.rem(8px);
			}
		}

		.reviews-wrapper {
			flex: 1 0 0;
			overflow: hidden;
			position: relative;
			@media #{layout.$medium-screen-and-smaller} {
				flex: 0 0 auto;
				width: 100%;
			}

			// Fade edges
			&::before,
			&::after {
				content: '';
				position: absolute;
				top: 0;
				bottom: 0;
				width: 78px;
				z-index: 1;
				pointer-events: none;
			}

			&::before {
				left: 0;
				background: linear-gradient(to right, colors.$color-white, transparent);
			}

			&::after {
				right: 0;
				background: linear-gradient(to left, colors.$color-white, transparent);
			}
		}

		.reviews-marquee {
			display: flex;
			width: max-content;
			will-change: transform;
			animation: marquee-scroll calc(var(--review-count, 4) * 3s) linear infinite;
		}

		.reviews-set {
			display: flex;
			flex-shrink: 0;
		}

		.review-item {
			display: flex;
			align-items: center;
			gap: fonts.rem(8px);
			flex-shrink: 0;
			white-space: nowrap;
			margin-right: fonts.rem(16px);

			.quote-content {
				font-family: fonts.$DM-Sans;
				font-weight: 400;
				font-size: fonts.rem(16px);
				line-height: 1.4;
				letter-spacing: -0.16px;
				color: colors.$color-black;
			}

			.reviewer-details {
				font-family: fonts.$DM-Sans;
				font-weight: 400;
				font-size: fonts.rem(16px);
				line-height: 1.4;
				letter-spacing: -0.16px;
				color: colors.$color-gray;
			}
		}
	}

	/*
	 * =============================
	 * Proactive Care Model
	 * =============================
	 */
	.proactive-care {
		background-color: colors.$color-white;
		padding: fonts.rem(32px) 0;

		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) 0;
		}

		.container {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: fonts.rem(24px);
			padding: fonts.rem(32px) fonts.rem(64px);

			@media #{layout.$medium-screen-and-smaller} {
				padding: 0 fonts.rem(16px);
			}
		}

		.title-block {
			text-align: center;

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;

				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
				}
			}
		}

		.cards-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: fonts.rem(32px);
			width: 100%;
			max-width: 1256px;

			@media #{layout.$medium-screen-and-smaller} {
				grid-template-columns: 1fr;
				gap: fonts.rem(16px);
			}
		}

		.proactive-card {
			display: flex;
			flex-direction: column;
			border: 1px solid #f0f0f0;
			border-radius: 15px;
			background-color: #f1f0ef;
			overflow: hidden;
			height: fonts.rem(360px);

			&:nth-child(1) {
				background:
					radial-gradient(56% 45% at 51% 75%, rgba(233, 210, 37, 0.5) 0%, rgba(233, 210, 37, 0) 100%),
					#f1f0ef;
			}

			&:nth-child(2) {
				background:
					radial-gradient(96% 96% at 54% 91%, #d2cec4 0%, rgba(210, 206, 196, 0) 68%),
					#f1f0ef;
			}

			&:nth-child(3) {
				background:
					radial-gradient(172% 111% at 62% 66%, #d2cec4 0%, rgba(210, 206, 196, 0) 68%),
					#f1f0ef;
			}

			&:nth-child(4) {
				background:
					radial-gradient(50% 130% at 50% 130%, rgba(233, 210, 37, 0.5) 0%, rgba(233, 210, 37, 0) 100%),
					#f1f0ef;
			}

			@media #{layout.$medium-screen-and-smaller} {
				height: auto;
				max-width: 700px;
				justify-self: center;
				width: 100%;
			}
		}

		.card-text {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(8px);
			padding: fonts.rem(24px) fonts.rem(24px) 0;

			@media #{layout.$medium-screen-and-smaller} {
				padding: fonts.rem(16px) fonts.rem(16px) 0;
			}
		}

		.card-heading {
			font-family: fonts.$DM-Sans;
			font-weight: 400;
			font-size: fonts.rem(28px);
			line-height: 1.1;
			letter-spacing: -0.56px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-weight: 500;
				font-size: fonts.rem(22px);
				letter-spacing: -0.44px;
			}
		}

		.card-description {
			font-family: fonts.$DM-Sans;
			font-weight: 400;
			font-size: fonts.rem(16px);
			line-height: 1.4;
			letter-spacing: -0.16px;
			color: colors.$color-black;
			margin: 0;

			@media #{layout.$medium-screen-and-smaller} {
				font-size: fonts.rem(14px);
				letter-spacing: -0.14px;
			}
		}

		.card-illustration {
			flex: 1;
			display: flex;
			align-items: flex-end;
			justify-content: center;
			padding: 0 fonts.rem(24px);
			overflow: hidden;

			@media #{layout.$medium-screen-and-smaller} {
				padding: 0 fonts.rem(16px);
			}

			lottie-player {
				width: 100%;
				max-width: 618px;
				max-height: 100%;
			}
		}

		.cta-block {
			width: fonts.rem(366px);

			@media #{layout.$medium-screen-and-smaller} {
				width: 100%;
				max-width: 700px;
			}
		}

		.cta-button {
			display: flex;
			align-items: center;
			justify-content: center;
			background-color: colors.$color-yellow;
			border: 1px solid colors.$color-gray-medium-transparent;
			color: colors.$color-black;
			font-family: fonts.$DM-Sans;
			font-weight: 500;
			font-size: fonts.rem(16px);
			line-height: 1.3;
			letter-spacing: -0.32px;
			height: fonts.rem(48px);
			padding: 0 fonts.rem(48px);
			border-radius: 2px;
			text-decoration: none;
			cursor: pointer;
			width: 100%;

			&:hover {
				background-color: colors.$color-yellow-dark;
			}
		}
	}

	/*
	 * =============================
	 * Longevity Timeline
	 * =============================
	 */
	.longevity-timeline {
		background-color: colors.$color-white;
		padding: fonts.rem(32px) 0;
		position: relative;
		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) 0;
		}

		.container {
			position: relative;
			z-index: 1;
			background-color: colors.$color-white;
			display: flex;
			flex-direction: column;
			gap: fonts.rem(32px);
			padding: fonts.rem(32px) 0 fonts.rem(80px);
			@media #{layout.$medium-screen-and-smaller} {
				padding: 0;
				gap: fonts.rem(40px);
				background-color: transparent;
			}
		}

		.title-block {
			text-align: center;

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
				font-size: fonts.rem(54px);
				line-height: 1;
				letter-spacing: -1.08px;
				color: colors.$color-black;
				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(36px);
					letter-spacing: -0.72px;
				}
			}
		}

		.timeline-wrapper {
			padding: 0;
		}

		.longevity-timeline-carousel {
			display: flex;
			justify-content: center;
			align-items: stretch;
			width: 100%;
			@media #{layout.$medium-screen-and-smaller} {
				justify-content: flex-start;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;

				&::-webkit-scrollbar {
					display: none;
				}
			}
		}

		.timeline-card {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(8px);
			width: 250px;
			flex-shrink: 0;
			opacity: 0.8;
			cursor: pointer;
			transition: width 0.4s ease, opacity 0.4s ease;
			@media only screen and (max-width: 1220px) {
				width: 184px;
			}
			@media #{layout.$medium-screen-and-smaller} {
				max-width: 325px;
				width: 100vw;
				opacity: 1;
				cursor: default;
				transition: none;
			}
			&:first-child {
				margin-left: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-left: fonts.rem(16px);
				}
			}
			&:last-child {
				margin-right: fonts.rem(32px);
				@media #{layout.$small-screen-only} {
					margin-right: fonts.rem(16px);
				}
			}

			.image-wrapper {
				padding: 0 fonts.rem(8px);
				height: 360px;
				display: flex;
				align-items: flex-end;
				@media #{layout.$medium-screen-and-smaller} {
					height: auto;
					align-items: stretch;
				}

				img {
					width: 100%;
					aspect-ratio: 1 / 1;
					object-fit: cover;
					border-radius: 15px;
					display: block;
					transition: border-radius 0.4s ease;
					@media #{layout.$medium-screen-and-smaller} {
						border-radius: 20px;
					}
				}
			}

			.divider-wrapper {
				display: flex;
				align-items: center;
				gap: fonts.rem(8px);
				padding-bottom: fonts.rem(8px);
				padding-left: fonts.rem(8px);

				.dot {
					width: 12px;
					height: 12px;
					border-radius: 8px;
					border: 3px solid #20C475;
					background: colors.$color-white;
					flex-shrink: 0;
					box-sizing: border-box;
				}

				.line {
					flex: 1;
					height: 1px;
					background-color: colors.$color-gray;
				}
			}

			.content-wrapper {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: fonts.rem(8px);
				padding: 0 fonts.rem(8px);
				text-align: left;

				.heading {
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(18px);
					line-height: 1.1;
					letter-spacing: -0.36px;
					color: colors.$color-black;
					margin: 0;
				}

				.description {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.4;
					letter-spacing: -0.14px;
					color: colors.$color-black;
					margin: 0;
					max-height: 0;
					overflow: hidden;
					opacity: 0;
					transition: max-height 0.4s ease, opacity 0.3s ease;
					@media #{layout.$medium-screen-and-smaller} {
						max-height: none;
						overflow: visible;
						opacity: 1;
					}
				}

				.steps-block {
					display: flex;
					flex-direction: column;
					gap: fonts.rem(12px);
					max-height: 0;
					overflow: hidden;
					opacity: 0;
					transition: max-height 0.4s ease, opacity 0.3s ease;
					@media #{layout.$medium-screen-and-smaller} {
						max-height: none;
						overflow: visible;
						opacity: 1;
					}
				}

				.step-item {
					border-left: 2px solid rgba(96, 91, 82, 0.2);
					padding-left: fonts.rem(8px);

					p {
						font-family: fonts.$DM-Sans;
						font-weight: 400;
						font-size: fonts.rem(14px);
						line-height: 1.4;
						letter-spacing: -0.14px;
						color: colors.$color-black;
						margin: 0;
					}
				}
			}

			// Active state
			&.active {
				width: 360px;
				opacity: 1;
				@media #{layout.$medium-screen-and-smaller} {
					max-width: 325px;
					width: 100vw;
				}

				.image-wrapper img {
					border-radius: 20px;
				}

				.content-wrapper {
					.description {
						max-height: 200px;
						opacity: 1;
					}

					.steps-block {
						max-height: 400px;
						opacity: 1;
					}
				}
			}
		}
	}

	/*
	 * =============================
	 * Real Moments Carousel
	 * =============================
	 */
	.real-moments {
		background-color: colors.$color-white;
		padding: fonts.rem(32px) 0;

		@media #{layout.$medium-screen-and-smaller} {
			padding: fonts.rem(40px) 0;
		}

		.container {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: fonts.rem(32px);
			padding: fonts.rem(32px) fonts.rem(64px);

			@media #{layout.$medium-screen-and-smaller} {
				padding: fonts.rem(40px) 0;
				gap: fonts.rem(24px);
			}
		}

		.title-block {
			text-align: center;
			width: 100%;

			.title {
				font-family: fonts.$STIX-Two-Text;
				font-weight: 400;
