		infinite: true,
		dots: true,
		appendDots: '.real-moments .real-moments-dots',
		arrows: false,
		accessibility: true,
		responsive: [
			{
				breakpoint: 1276,
				settings: {
					slidesToShow: 3,
					slidesToScroll: 1,
				},
			},
			{
				breakpoint: 1025,
				settings: {
					variableWidth: true,
					slidesToShow: 1,
					slidesToScroll: 1,
					accessibility: false,
				},
