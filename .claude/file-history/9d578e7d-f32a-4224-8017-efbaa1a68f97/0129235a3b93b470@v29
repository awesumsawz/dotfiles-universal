	/*
	 * =============================
	 * Buy Box Section
	 * =============================
	 */
	.buy-box {
		background-color: colors.$color-white;

		.container {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: fonts.rem(64px);
			align-items: start;
			padding: fonts.rem(40px) fonts.rem(64px);

			@media #{layout.$medium-screen-and-smaller} {
				grid-template-columns: 1fr;
				gap: fonts.rem(24px);
				padding: fonts.rem(40px) 0;
			}
		}

		// Left — image gallery
		.gallery-wrapper {
			.image-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: fonts.rem(8px);

				.grid-tile {
					aspect-ratio: 1 / 1;
					overflow: hidden;
					border-radius: fonts.rem(8px);
					background-color: #f1f0ef;

					img {
						width: 100%;
						height: 100%;
						object-fit: cover;
						display: block;
					}
				}
			}

			// Mobile carousel + thumbs
			.buy-box-slider-wrapper {
				overflow: hidden;
				min-width: 0;

				.buy-box-main-carousel {
					position: relative;
					display: flex;
					overflow-x: auto;
					scroll-snap-type: x mandatory;
					-webkit-overflow-scrolling: touch;
					scrollbar-width: none;
					gap: fonts.rem(8px);
					margin-bottom: fonts.rem(12px);
					cursor: grab;
					padding-left: fonts.rem(32px);
					scroll-padding-left: fonts.rem(32px);

					@media #{layout.$small-screen-and-smaller} {
						padding-left: fonts.rem(16px);
						scroll-padding-left: fonts.rem(16px);
					}

					&::-webkit-scrollbar {
						display: none;
					}

					&::after {
						content: '';
						flex-shrink: 0;
						width: fonts.rem(32px);
						order: 9999;
					}

					.slide {
						scroll-snap-align: start;
						flex-shrink: 0;
						width: calc(100% - #{fonts.rem(32px)});
						max-width: fonts.rem(462px);

						@media #{layout.$small-screen-and-smaller} {
							width: calc(100% - #{fonts.rem(16px)});
						}

						img {
							width: 100%;
							aspect-ratio: 1 / 1;
							object-fit: cover;
							display: block;
							border-radius: fonts.rem(8px);
						}
					}
				}

				.buy-box-thumbs {
					display: flex;
					gap: fonts.rem(8px);
					padding: 0 fonts.rem(32px);

					@media #{layout.$small-screen-and-smaller} {
						padding: 0 fonts.rem(16px);
					}

					.thumb {
						flex: 1 1 0;
						min-width: 0;
						cursor: pointer;

						img {
							width: 100%;
							aspect-ratio: 1 / 1;
							object-fit: cover;
							display: block;
							border-radius: fonts.rem(4px);
							border: 2px solid transparent;
							opacity: 0.5;
							transition: opacity 0.2s ease, border-color 0.2s ease;
						}

						&.active img {
							opacity: 1;
							border-color: colors.$color-black;
						}
					}
				}
			}
		}

		// Right — content + FAQs
		.content-wrapper {
			display: flex;
			flex-direction: column;
			gap: 0;

			@media #{layout.$medium-screen-and-smaller} {
				padding-inline: fonts.rem(32px);
			}

			@media #{layout.$small-screen-and-smaller} {
				padding-inline: fonts.rem(16px);
			}
		}

		.content-block {
			display: flex;
			flex-direction: column;
			gap: fonts.rem(24px);

			.title-block {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: fonts.rem(16px);

				.title {
					font-family: fonts.$STIX-Two-Text;
					font-weight: 400;
					font-size: fonts.rem(54px);
					line-height: 1;
					letter-spacing: -1.08px;
					color: colors.$color-black;

					@media #{layout.$medium-screen-and-smaller} {
						font-size: fonts.rem(36px);
						letter-spacing: -0.72px;
					}
				}

				.price {
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(32px);
					line-height: 1.1;
					letter-spacing: -0.64px;
					color: colors.$color-black;
					white-space: nowrap;
					flex-shrink: 0;

					@media #{layout.$medium-screen-and-smaller} {
						font-size: fonts.rem(28px);
						letter-spacing: -0.56px;
					}
				}
			}

			.description {
				font-family: fonts.$DM-Sans;
				font-weight: 500;
				font-size: fonts.rem(22px);
				line-height: 1.1;
				letter-spacing: -0.44px;
				color: colors.$color-black;

				@media #{layout.$medium-screen-and-smaller} {
					font-size: fonts.rem(18px);
					letter-spacing: -0.36px;
				}
			}

			.feature-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: fonts.rem(16px);

				@media #{layout.$medium-screen-and-smaller} {
					gap: fonts.rem(12px);
				}

				li {
					border-left: 2px solid rgba(96, 91, 82, 0.2);
					padding-left: fonts.rem(12px);
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(22px);
					line-height: 1.1;
					letter-spacing: -0.44px;
					color: colors.$color-black;

					@media #{layout.$medium-screen-and-smaller} {
						font-size: fonts.rem(18px);
						letter-spacing: -0.36px;
						padding-left: fonts.rem(8px);
					}
				}
			}

			.cta-block {
				display: flex;
				flex-direction: column;
				gap: fonts.rem(8px);

				.cta-button {
					display: flex;
					align-items: center;
					justify-content: center;
					width: 100%;
					height: fonts.rem(48px);
					background-color: colors.$color-yellow;
					border: 1px solid rgba(14, 11, 32, 0.2);
					border-radius: 2px;
					padding: 0 fonts.rem(48px);
					color: colors.$color-black;
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(16px);
					line-height: 1.3;
					letter-spacing: -0.32px;
					text-decoration: none;
					cursor: pointer;
					box-sizing: border-box;

					&:hover {
						background-color: colors.$color-yellow-dark;
					}
				}

				.badges-wrapper {
					display: flex;
					flex-wrap: wrap;
					align-items: center;
					justify-content: center;
					gap: fonts.rem(10px);

					.badge {
						display: flex;
						align-items: center;
						gap: fonts.rem(4px);
						height: 20px;

						img {
							width: auto;
							height: 24px;
						}

						span {
							font-family: fonts.$DM-Sans;
							font-weight: 400;
							font-size: fonts.rem(14px);
							line-height: 1.4;
							letter-spacing: -0.28px;
							color: colors.$color-gray;
						}
					}
				}
			}
		}

		// FAQ accordion
		.faq-block {
			margin-top: fonts.rem(40px);

			.faq-item {
				border-bottom: 1px solid rgba(96, 91, 82, 0.2);

				&:first-child {
					border-top: 1px solid rgba(96, 91, 82, 0.2);
				}
			}

			.faq-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: fonts.rem(12px) 0;
				cursor: pointer;
				gap: fonts.rem(16px);

				.faq-question {
					font-family: fonts.$DM-Sans;
					font-weight: 500;
					font-size: fonts.rem(18px);
					line-height: 1.1;
					letter-spacing: -0.36px;
					color: #202020;
				}

				.faq-icon {
					display: flex;
					align-items: center;
					justify-content: center;
					width: 24px;
					height: 24px;
					flex-shrink: 0;
					position: relative;

					.icon-line {
						position: absolute;
						background-color: colors.$color-black;
						transition: transform 0.3s ease;
					}

					.line-horizontal {
						width: 24px;
						height: 1px;
					}

					.line-vertical {
						width: 1px;
						height: 24px;
					}
				}
			}

			.faq-content {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.4s ease;

				.faq-item-answer {
					padding: 0 0 fonts.rem(16px);
					font-family: fonts.$DM-Sans;
					font-weight: 400;
					font-size: fonts.rem(14px);
					line-height: 1.4;
					letter-spacing: -0.14px;
					color: colors.$color-black;
				}
			}

			.faq-item.active {
				.faq-icon .line-vertical {
					transform: rotate(90deg);
				}

				.faq-content {
					max-height: 500px;
				}
			}
		}
	}
}

@keyframes marquee-scroll {
	from {
		transform: translateX(0);
	}
	to {
		transform: translateX(var(--marquee-offset, -50%));
	}
}
